# Copy this file to .env and fill in the values.
#
# VITE_API_URL — Full URL to the FastAPI backend INCLUDING the /api prefix.
# Examples:
#   Local dev (no proxy override needed, leave blank):
#     VITE_API_URL=
#   Deployed on Render / Railway / Fly.io:
#     VITE_API_URL=https://your-backend-service.up.railway.app/api
#   Deployed on Supabase Edge Functions or custom domain:
#     VITE_API_URL=https://api.yourdomain.com/api

VITE_API_URL=
